# =============================================================================
# Environment template -- copy to .env and fill in the four secrets.
#
# .env is loaded via python-dotenv at every entrypoint (pipeline/lib/redash.py,
# pipeline/lib/cds.py, exploration/run_phase1.py). Without these values, the
# Redash + CDS calls will fail with HTTP 401 / 403.
#
# DO NOT COMMIT YOUR FILLED-IN .env -- the workspace .gitignore excludes it.
# =============================================================================


# ---------------------------------------------------------------------------
# REQUIRED. Redash personal API key. Used by pipeline/lib/redash.py to call
# every analysis::* / diagnose::* / adhoc::* query.
#
# Get one from: https://redash.scale.com/users/me -> "API Key" tab.
# ---------------------------------------------------------------------------
REDASH_API_KEY=


# ---------------------------------------------------------------------------
# REQUIRED for CDS payload downloads. Used by pipeline/lib/cds.py to fetch
# per-task-attempt RESPONSE blobs from the Scale dashboard (Snowflake's
# CDS view is a redirector; the actual data lives in the dashboard).
#
# Get all three from your browser dev tools after logging into
# https://dashboard.scale.com:
#
#   * SCALE_DASHBOARD_JWT          -> "auth_jwt" cookie value
#   * SCALE_DASHBOARD_CSRF         -> x-csrf-token request header (any XHR)
#   * SCALE_DASHBOARD_CSRF_COOKIE  -> "_csrf" cookie value
#
# These rotate; if you start seeing 401s, refresh them.
# ---------------------------------------------------------------------------
SCALE_DASHBOARD_JWT=
SCALE_DASHBOARD_CSRF=
SCALE_DASHBOARD_CSRF_COOKIE=


# ---------------------------------------------------------------------------
# OPTIONAL. Absolute path to the local rl_envs/ directory that holds
# OpenClaw universe zips. Used by:
#
#   * analysis.run_env_coverage  (which universes referenced in CDS are
#                                 missing locally?)
#   * analysis.run_g2 phase-b    (per-audit bundle materialization; LLM
#                                 auditor reads the seed universe to verify
#                                 rubric criteria)
#
# If unset, defaults to ./rl_envs in the workspace root. The G2 phase-b
# audit will skip universe loading (degraded but functional) for any audit
# whose universe isn't found locally.
#
# Example (the path used on the original dev box):
#   RL_ENVS_DIR=/Users/<you>/Documents/openclaw_mm/rl_envs
# ---------------------------------------------------------------------------
RL_ENVS_DIR=
